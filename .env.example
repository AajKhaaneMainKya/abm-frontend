# ── ABM frontend environment ─────────────────────────────────
# Copy to .env.local and fill in real values. .env.local is gitignored.

# Backend API base (FastAPI on Railway). No trailing slash.
NEXT_PUBLIC_API_URL=https://abm-api-production-ff24.up.railway.app

# ── Clerk auth ───────────────────────────────────────────────
# From the Clerk Dashboard → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Clerk v7 redirect URLs. Sign-in/up is hosted on the /welcome splash.
# (These are the v7 names — the older NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL
#  style still works but logs a deprecation warning.)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/welcome
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/welcome
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding
